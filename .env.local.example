# =============================================================================
# Togather - Convex Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# Run `npx convex dev` to generate this file automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex Configuration (auto-generated by npx convex dev)
# -----------------------------------------------------------------------------
# Deployment URL - points to your Convex backend
# Format: https://<deployment-name>.convex.cloud
CONVEX_DEPLOYMENT=

# -----------------------------------------------------------------------------
# External Services (set these in Convex Dashboard -> Settings -> Environment Variables)
# -----------------------------------------------------------------------------
# These are stored securely in Convex, not in this file.
# Go to: https://dashboard.convex.dev -> Your Project -> Settings -> Environment Variables
#
# Required:
# - TWILIO_ACCOUNT_SID: For SMS verification
# - TWILIO_AUTH_TOKEN: For SMS verification
#
# Cloudflare R2 (image storage):
# - R2_ACCESS_KEY_ID: R2 access key
# - R2_SECRET_ACCESS_KEY: R2 secret key
# - R2_BUCKET_NAME: R2 bucket name
# - R2_PUBLIC_URL: Public URL for serving images
#
# -----------------------------------------------------------------------------
