{
  "name": "mobile",
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "dev": "node scripts/dev-wrapper.js",
    "build": "expo export",
    "serve": "npx expo export --platform web && node scripts/serve-with-og.js",
    "serve:quick": "node scripts/serve-with-og.js",
    "build:local": "npm run validate-eas && npm run build",
    "validate-eas": "node scripts/validate-eas.js",
    "validate-eas-cli": "npx eas-cli@latest build:configure --non-interactive || npx eas-cli@latest config --non-interactive",
    "builds:list": "npx eas-cli@latest build:list --platform all --limit 10",
    "builds:logs": "npx eas-cli@latest build:view",
    "deploy:web": "./scripts/deploy-web-all.sh",
    "deploy:web:prod": "./scripts/deploy-web-all.sh --prod",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "node run-tests.js",
    "fingerprint:check": "node scripts/check-fingerprint.js",
    "fingerprint:update": "node scripts/check-fingerprint.js --update",
    "version:bump": "node scripts/bump-version.js",
    "update:ota": "node scripts/safe-update.js",
    "postinstall": "patch-package",
    "eas-build-pre-install": "which pnpm > /dev/null 2>&1 || (corepack enable && corepack prepare pnpm@8.15.0)"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.patch.js",
      "<rootDir>/jest.setup.js"
    ],
    "testTimeout": 5000,
    "forceExit": true,
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/)?((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|@expo/vector-icons/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|@sentry/.*|native-base|react-native-svg|@tanstack/react-query|date-fns|bad-words|badwords-list))"
    ],
    "testMatch": [
      "**/__tests__/**/*.(ts|tsx|js)",
      "**/*.(test|spec).(ts|tsx|js)"
    ],
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "components/**/*.{ts,tsx}",
      "services/**/*.{ts,tsx}",
      "providers/**/*.{ts,tsx}",
      "!**/*.d.ts",
      "!**/node_modules/**"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@features/(.*)$": "<rootDir>/features/$1",
      "^@components/(.*)$": "<rootDir>/components/$1",
      "^@services/(.*)$": "<rootDir>/services/$1",
      "^@utils/(.*)$": "<rootDir>/utils/$1",
      "^@types/(.*)$": "<rootDir>/types/$1",
      "^@providers/(.*)$": "<rootDir>/providers/$1",
      "^@hooks/(.*)$": "<rootDir>/hooks/$1",
      "^@togather/shared/(.*)$": "<rootDir>/../../packages/shared/src/$1",
      "^@togather/shared$": "<rootDir>/../../packages/shared/src/index.ts",
      "^react$": "<rootDir>/node_modules/react",
      "^react/jsx-runtime$": "<rootDir>/node_modules/react/jsx-runtime",
      "^react/jsx-dev-runtime$": "<rootDir>/node_modules/react/jsx-dev-runtime",
      "^react-test-renderer$": "<rootDir>/node_modules/react-test-renderer"
    }
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^3.9.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.5.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-picker/picker": "2.11.1",
    "@sentry/browser": "^10.36.0",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "^2.2.0",
    "@togather/shared": "workspace:*",
    "axios": "^1.7.7",
    "bad-words": "^4.0.0",
    "convex": "^1.31.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "expo": "~54.0.23",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.8",
    "expo-av": "^16.0.8",
    "expo-blur": "~15.0.8",
    "expo-calendar": "~15.0.8",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.12",
    "expo-contacts": "~15.0.11",
    "expo-crypto": "~15.0.7",
    "expo-device": "~8.0.10",
    "expo-document-picker": "^14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.8",
    "expo-intent-launcher": "~13.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.8",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-mail-composer": "~15.0.8",
    "expo-media-library": "~18.2.0",
    "expo-notifications": "~0.32.15",
    "expo-router": "~6.0.14",
    "expo-secure-store": "~15.0.7",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sms": "~14.0.8",
    "expo-status-bar": "~3.0.8",
    "expo-updates": "^29.0.15",
    "expo-web-browser": "~15.0.9",
    "mapbox-gl": "^3.20.0",
    "maplibre-gl": "^4.0.0",
    "papaparse": "^5.5.3",
    "posthog-react-native": "^4.24.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.53.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.20.2",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "supercluster": "^8.0.1",
    "superjson": "^2.2.6",
    "us-zips": "^2022.9.1",
    "zipcodes": "^8.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@expo/server": "^0.7.5",
    "@jest/test-sequencer": "^29.7.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.0",
    "@types/supercluster": "^7.1.3",
    "@types/zipcodes": "^8.0.5",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.13",
    "openapi-typescript": "^6.0.0",
    "patch-package": "^8.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@8.15.0",
  "private": true
}
