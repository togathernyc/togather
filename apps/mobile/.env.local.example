# =============================================================================
# Togather Mobile App - Local Development Overrides
# =============================================================================
# Copy this file to .env.local for local development overrides.
#
# IMPORTANT: These are EXPO_PUBLIC_ variables, meaning they are bundled into
# the app and visible to users. Never put secrets here!
# =============================================================================

# -----------------------------------------------------------------------------
# Convex Backend (Required)
# -----------------------------------------------------------------------------
# The Convex deployment URL for the mobile app to connect to.
# Format: https://<deployment-name>.convex.cloud
#
# For development, run `npx convex dev` in apps/convex to get your deployment URL.
# The URL will be printed in the terminal output.
#
# Example (development): https://your-dev-deployment.convex.cloud
# Example (staging): https://your-staging-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# -----------------------------------------------------------------------------
# Mapbox (Required for maps)
# -----------------------------------------------------------------------------
# Mapbox PUBLIC access token (pk.* token, not sk.*)
# IMPORTANT: Use a PUBLIC token (starts with pk.*), NOT a secret token (sk.*)
# Get from: Vault -> togather/{env}/mapbox/public_token
# Or from: https://account.mapbox.com/access-tokens/
# Create a new token with the following scopes:
#   - styles:read (for map styles)
#   - fonts:read (for map fonts)
#   - datasets:read (for datasets)
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token-here

# -----------------------------------------------------------------------------
# PostHog Analytics (Optional)
# -----------------------------------------------------------------------------
# PostHog project API key for analytics and feature flags
# Get from: https://us.posthog.com -> Project Settings -> Project API Key
# Leave empty to disable analytics
EXPO_PUBLIC_POSTHOG_API_KEY=your_posthog_api_key_here

# -----------------------------------------------------------------------------
# Sentry Error Tracking (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking and performance monitoring
# Get from: https://sentry.io -> Project Settings -> Client Keys (DSN)
# Leave empty to disable error tracking
EXPO_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Development Notes
# -----------------------------------------------------------------------------
# The mobile app environment is determined at BUILD TIME via APP_VARIANT:
# - Development builds connect to the deployment URL specified above
# - Staging builds (APP_VARIANT=staging) use staging API
# - Production builds use production API
#
# Test login: Phone 2025550123, Code: 000000
# The magic OTP code "000000" works for test phone numbers in all environments.
# =============================================================================
