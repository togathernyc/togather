# Togather Environment Variables
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# =============================================================================
# CONVEX (Required)
# =============================================================================
CONVEX_DEPLOYMENT=              # Your Convex deployment name (e.g., "your-deployment-123")
CONVEX_DEPLOY_KEY=              # Convex deploy key for production deployments

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
JWT_SECRET=                     # Secret for signing JWT tokens
DEV_OTP_BYPASS=                 # Set to "true" to use bypass OTP code "000000" in dev
OTP_BYPASS_CODE=                # Custom OTP bypass code for staff login testing

# =============================================================================
# TWILIO SMS (Required for production, optional for dev)
# =============================================================================
TWILIO_ACCOUNT_SID=             # Twilio account SID
TWILIO_AUTH_TOKEN=              # Twilio auth token
TWILIO_PHONE_NUMBER=            # Twilio sender phone number
TWILIO_VERIFY_SERVICE_SID=      # Twilio Verify service SID

# =============================================================================
# CLOUDFLARE R2 (Required for image storage)
# =============================================================================
R2_ACCESS_KEY_ID=               # R2 access key
R2_SECRET_ACCESS_KEY=           # R2 secret key
R2_BUCKET_NAME=                 # R2 bucket name
R2_PUBLIC_URL=                  # Public URL for serving images
CLOUDFLARE_ACCOUNT_ID=          # Cloudflare account ID
CLOUDFLARE_ZONE_ID=             # Cloudflare zone ID (for Workers)

# =============================================================================
# EMAIL (Optional - for transactional emails)
# =============================================================================
RESEND_API_KEY=                 # Resend API key (transactional emails)

# =============================================================================
# EXPO / EAS (Mobile builds)
# =============================================================================
EXPO_TOKEN=                     # Expo/EAS authentication token
EXPO_OWNER=                     # Expo account owner
EAS_PROJECT_ID=                 # EAS project ID
EXPO_PUBLIC_CONVEX_URL=         # Convex deployment URL for the mobile app
EXPO_PUBLIC_PROJECT_ID=         # Expo project ID for push notifications

# =============================================================================
# SLACK (Optional - for team notifications)
# =============================================================================
SLACK_BOT_TOKEN=                # Slack bot OAuth token
SLACK_WEBHOOK_URL=              # Slack incoming webhook URL
SLACK_BOT_USER_ID=              # Slack bot user ID
SLACK_PROD_CHANNEL_ID=          # Slack production channel ID
SLACK_DEV_CHANNEL_ID=           # Slack development channel ID

# =============================================================================
# SENTRY (Optional - error tracking)
# =============================================================================
SENTRY_DSN=                     # Sentry DSN
SENTRY_ORG=                     # Sentry organization slug
SENTRY_PROJECT=                 # Sentry project slug

# =============================================================================
# MAPBOX (Optional - for maps)
# =============================================================================
MAPBOX_ACCESS_TOKEN=            # Mapbox server-side token
EXPO_PUBLIC_MAPBOX_TOKEN=       # Mapbox public token (pk.*)

# =============================================================================
# GOOGLE MAPS (Required for Android native maps)
# =============================================================================
GOOGLE_MAPS_API_KEY=            # Google Maps SDK for Android API key

# =============================================================================
# PLANNING CENTER (Optional - church management integration)
# =============================================================================
PLANNING_CENTER_CLIENT_ID=      # Planning Center OAuth client ID
PLANNING_CENTER_CLIENT_SECRET=  # Planning Center OAuth secret
PCO_PROD_COMMUNITY_ID=         # Planning Center production community ID
PCO_DEV_COMMUNITY_ID=          # Planning Center development community ID

# =============================================================================
# KLIPY GIF API (Optional - for GIF picker in chat)
# =============================================================================
EXPO_PUBLIC_KLIPY_API_KEY=       # KLIPY API key (get from partner.klipy.com)

# =============================================================================
# IMAGE CDN (Optional - custom domain)
# =============================================================================
EXPO_PUBLIC_IMAGE_CDN_URL=      # Custom image CDN URL
VITE_IMAGE_CDN_URL=             # Image CDN URL for web app
IMAGE_CDN_HOSTNAME=             # Image CDN hostname (for link preview worker)
