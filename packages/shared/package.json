{
  "name": "@togather/shared",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./api/services": {
      "types": "./dist/api/services/index.d.ts",
      "default": "./dist/api/services/index.js"
    },
    "./api/instance": {
      "types": "./dist/api/instance.d.ts",
      "default": "./dist/api/instance.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./utils/storage": {
      "types": "./dist/utils/storage.d.ts",
      "default": "./dist/utils/storage.js"
    },
    "./utils/api-response": {
      "types": "./dist/utils/api-response.d.ts",
      "default": "./dist/utils/api-response.js"
    },
    "./utils/query-keys": {
      "types": "./dist/utils/query-keys.d.ts",
      "default": "./dist/utils/query-keys.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./config/domain": {
      "types": "./src/config/domain.d.ts",
      "default": "./src/config/domain.js"
    },
    "./stream": {
      "types": "./dist/stream/index.d.ts",
      "default": "./dist/stream/index.js"
    }
  },
  "scripts": {
    "build": "tsc && cp src/config/domain.js src/config/domain.d.ts dist/config/",
    "test": "jest --passWithNoTests",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "date-fns-tz": "^3.2.0",
    "superjson": "^2.2.6"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "*",
    "@tanstack/react-query": "^5.56.2",
    "expo-secure-store": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "msw": "^1.3.2",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  }
}
