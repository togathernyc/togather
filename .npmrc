# Prevent hoisting of React and testing packages to root
# This ensures packages are resolved from workspace packages, not root
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@jest/*
shamefully-hoist=true

# Private GitHub Packages registry for @supa-media/* (Supa Framework).
# GITHUB_TOKEN must be set in the environment (CI: secrets.GITHUB_TOKEN;
# local: `gh auth token`) — see CLAUDE.md's "Supa Framework" section.
@supa-media:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}

